# JWT 配置
JWT_SECRET_KEY=your-secret-key-here-change-in-production

# Redis 配置
REDIS_PORT=6379
REDIS_PASSWORD=foobared

# GitHub OAuth2 配置
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URL=http://localhost:8000/api/v1/oauth/redirect

# LLM 配置 (OpenAI)
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o

# DataSource 配置
DATASOURCE_URL=jdbc:mysql://localhost:3306/springboot_demo?characterEncoding=utf8
DATASOURCE_USERNAME=root
DATASOURCE_PASSWORD=root

# Mail 邮件配置 (以 QQ 邮箱为例)
# 1. 登录 QQ 邮箱网页版 → 设置 → 账户
# 2. 找到 POP3/IMAP/SMTP/Exchange/CardDAV/CalDAV服务
# 3. 开启 SMTP 服务
# 4. 点击"生成授权码"（需短信验证），复制授权码填入 MAIL_PASSWORD
# 5. MAIL_USERNAME 仅填 QQ 号（不含 @qq.com），MAIL_FROM 填完整邮箱地址
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your-qq-number
MAIL_PASSWORD=your-authorization-code
MAIL_FROM=your-email@qq.com
